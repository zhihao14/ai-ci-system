# ============================================================
# 复制为 .env 并填入真实凭据 (backend/.env 与 crawler 共用此配置)
# ============================================================

# ---- Supabase ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# ---- Supabase 前端 (浏览器端可见, 使用 anon key) ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ---- DeepSeek (OpenAI 兼容接口, 主用) ----
DEEPSEEK_API_KEY=your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ---- Anthropic Claude (备用, DeepSeek 失败时自动切换) ----
ANTHROPIC_API_KEY=your-anthropic-key
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# ---- OpenAI (AI Router 可选) ----
# OPENAI_API_KEY=your-openai-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# ---- GLM / 智谱 (AI Router 可选) ----
# GLM_API_KEY=your-glm-key
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# GLM_MODEL=glm-4

# ---- 自定义第三方 API (AI Router 可选) ----
# CUSTOM_AI_NAME=custom
# CUSTOM_AI_TYPE=openai
# CUSTOM_AI_BASE_URL=https://your-api.com/v1
# CUSTOM_AI_API_KEY=your-key
# CUSTOM_AI_MODEL=your-model

# ---- 爬虫脚本路径 (相对 backend 目录) ----
CRAWLER_SCRIPT=../crawler/crawl.js
# 抖音爬虫脚本路径 (相对 backend 目录)
CRAWLER_DOUYIN_SCRIPT=../crawler/douyin/crawl_douyin.js
# 多平台爬虫: 路径由 crawler_manager.py 自动路由, 无需单独配置
# 小红书: crawler/xiaohongshu/crawl_xiaohongshu.js
# YouTube: crawler/youtube/crawl_youtube.js
# TikTok:  crawler/tiktok/crawl_tiktok.js
# 后端服务端口
PORT=8000
# 多平台采集模块端口
PORT_MULTI=8003

# ---- 异常检测系统配置 ----
ANOMALY_WINDOW_HOURS=2          # 检测窗口 (小时)
ANOMALY_BASELINE_DAYS=7         # 基线天数
ANOMALY_Z_MEDIUM=2.0           # Z-score 中度异常阈值
ANOMALY_Z_HIGH=3.0            # Z-score 高度异常阈值
ANOMALY_Z_CRITICAL=4.0        # Z-score 严重异常阈值
ANOMALY_MIN_LIKES=100         # 点赞最小增长阈值 (低于不判定)
ANOMALY_MIN_COMMENTS=20        # 评论最小增长阈值
ANOMALY_MIN_FOLLOWERS=50      # 粉丝最小增长阈值
VIRAL_LIKE_THRESHOLD=5000    # 2h点赞超此值标记爆款

# ---- 通知配置 ----
NOTIFY_WEBHOOK_URL=            # 通用 Webhook (飞书/钉钉/Slack)
NOTIFY_WEBHOOK_HEADERS={"Content-Type":"application/json"}
NOTIFY_MIN_SEVERITY=medium    # 最低通知严重度
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email
# SMTP_PASS=your-password
# SMTP_FROM=your-email@gmail.com
# NOTIFY_EMAIL_TO=recipient@gmail.com

# ---- 自动监控调度系统 ----
MONITOR_MAX_ACCOUNTS=100      # 每轮扫描账号上限
MONITOR_MAX_VIDEOS=20        # 每账号爬取视频上限
MONITOR_ANALYZE=true         # 是否自动 AI 分析
MONITOR_ANALYSIS_MODEL=auto  # 分析模型: auto/deepseek/claude

# ---- 实时通知 WebSocket ----
# 前端浏览器连接 (直连, 不走 Next.js 代理)
NEXT_PUBLIC_WS_URL=ws://localhost:8010/ws

# ---- API Marketplace ----
# 开发者 API Key 前缀
MARKETPLACE_KEY_PREFIX=mk_
# 默认限流 (free 套餐)
MARKETPLACE_FREE_RATE_PER_MIN=10
MARKETPLACE_FREE_RATE_PER_DAY=100
